@if (_messages.Any())
{
    <div class="toast-container">
        @foreach (var msg in _messages)
        {
            <div class="toast toast--@msg.Type @(msg.Visible ? "toast--in" : "toast--out")">
                <span class="toast__icon">@GetIcon(msg.Type)</span>
                <span class="toast__text">@msg.Text</span>
                <button class="toast__close" @onclick="() => Remove(msg)">×</button>
            </div>
        }
    </div>
}

@code {
    private readonly List<ToastMessage> _messages = new();

    public void Show(string text, string type = "info")
    {
        var msg = new ToastMessage { Text = text, Type = type, Visible = true };
        _messages.Add(msg);
        StateHasChanged();

        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            msg.Visible = false;
            InvokeAsync(StateHasChanged);
            Task.Delay(400).ContinueWith(_ =>
            {
                _messages.Remove(msg);
                InvokeAsync(StateHasChanged);
            });
        });
    }

    public void Success(string text) => Show(text, "success");
    public void Error(string text)   => Show(text, "error");
    public void Info(string text)    => Show(text, "info");

    private void Remove(ToastMessage msg)
    {
        _messages.Remove(msg);
        StateHasChanged();
    }

    private static string GetIcon(string type) => type switch
    {
        "success" => "✓",
        "error"   => "✕",
        "warning" => "⚠",
        _         => "ℹ"
    };

    private sealed class ToastMessage
    {
        public string Text    { get; set; } = string.Empty;
        public string Type    { get; set; } = "info";
        public bool   Visible { get; set; }
    }
}
