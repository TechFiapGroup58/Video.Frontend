@inject IAuthService Auth
@inject NavigationManager Nav

@if (_checked)
{
    if (_authenticated || _isPublicPage)
    {
        @ChildContent
    }
    else
    {
        <div class="loading-screen">
            <div class="spinner"></div>
        </div>
    }
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _checked       = false;
    private bool _authenticated = false;
    private bool _isPublicPage  = false;

    private static readonly HashSet<string> PublicRoutes = new(StringComparer.OrdinalIgnoreCase)
    {
        "/login", "/register", "/"
    };

    protected override async Task OnInitializedAsync()
    {
        var path = new Uri(Nav.Uri).AbsolutePath;
        _isPublicPage  = PublicRoutes.Contains(path);
        _authenticated = await Auth.IsAuthenticatedAsync();
        _checked       = true;

        if (!_authenticated && !_isPublicPage)
            Nav.NavigateTo("/login");

        if (_authenticated && _isPublicPage && path is "/login" or "/register")
            Nav.NavigateTo("/dashboard");
    }
}
