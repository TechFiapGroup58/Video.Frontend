@page "/upload"
@inject IUploadService Upload
@inject NavigationManager Nav

<PageTitle>Enviar Vídeo — FIAP X</PageTitle>

<div class="page">
    <div class="page__header">
        <div>
            <h1 class="page__title">Enviar Vídeo</h1>
            <p class="page__subtitle">Formatos aceitos: mp4, avi, mov, mkv, webm — até 2 GB</p>
        </div>
    </div>

    <div class="upload-card">
        @if (_state == UploadState.Idle)
        {
            <div class="dropzone @(_dragging ? "dropzone--active" : "")"
                 @ondragover:preventDefault="true"
                 @ondragover="() => _dragging = true"
                 @ondragleave="() => _dragging = false"
                 @ondrop="HandleDrop"
                 @ondrop:preventDefault="true">
                <span class="dropzone__icon">↑</span>
                <p class="dropzone__title">Arraste o vídeo aqui</p>
                <p class="dropzone__sub">ou</p>
                <label class="btn btn--secondary">
                    Selecionar arquivo
                    <InputFile OnChange="HandleFileSelected" accept="video/*" class="visually-hidden" />
                </label>
            </div>

            @if (_file is not null)
            {
                <div class="file-preview">
                    <div class="file-preview__info">
                        <span class="file-preview__name">@_file.Name</span>
                        <span class="file-preview__size">@FormatSize(_file.Size)</span>
                    </div>
                    <button class="btn btn--primary" @onclick="HandleUpload">
                        ↑ Enviar agora
                    </button>
                    <button class="btn btn--ghost" @onclick="() => _file = null">Cancelar</button>
                </div>
            }
        }
        else if (_state == UploadState.Uploading)
        {
            <div class="upload-progress">
                <div class="spinner spinner--lg"></div>
                <p>Enviando <strong>@_file?.Name</strong>...</p>
                <p class="upload-progress__sub">Não feche a janela</p>
            </div>
        }
        else if (_state == UploadState.Success)
        {
            <div class="upload-result upload-result--success">
                <span class="upload-result__icon">✓</span>
                <h2>Upload realizado!</h2>
                <p>O vídeo foi enviado e está na fila de processamento.</p>
                <div class="upload-result__actions">
                    <a href="/videos" class="btn btn--primary">Ver meus vídeos</a>
                    <button class="btn btn--secondary" @onclick="Reset">Enviar outro</button>
                </div>
            </div>
        }
        else if (_state == UploadState.Error)
        {
            <div class="upload-result upload-result--error">
                <span class="upload-result__icon">✕</span>
                <h2>Falha no upload</h2>
                <p>@_error</p>
                <button class="btn btn--secondary" @onclick="Reset">Tentar novamente</button>
            </div>
        }
    </div>
</div>

@code {
    private enum UploadState { Idle, Uploading, Success, Error }

    private IBrowserFile? _file;
    private UploadState   _state   = UploadState.Idle;
    private string        _error   = string.Empty;
    private bool          _dragging = false;

    private static readonly HashSet<string> AllowedTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "video/mp4", "video/mpeg", "video/avi",
        "video/quicktime", "video/x-matroska", "video/webm"
    };

    private void HandleFileSelected(InputFileChangeEventArgs e)
        => _file = e.File;

    private void HandleDrop(DragEventArgs e)
    {
        _dragging = false;
        // Drag-and-drop de arquivo é tratado via JS interop em Blazor WASM
        // O InputFile acima cobre o caso mais comum
    }

    private async Task HandleUpload()
    {
        if (_file is null) return;

        if (!AllowedTypes.Contains(_file.ContentType))
        {
            _error = $"Formato '{_file.ContentType}' não suportado.";
            _state = UploadState.Error;
            return;
        }

        _state = UploadState.Uploading;

        try
        {
            const long maxSize = 2L * 1024 * 1024 * 1024;
            await using var stream = _file.OpenReadStream(maxSize);

            await Upload.UploadAsync(stream, _file.Name, _file.ContentType, _file.Size);
            _state = UploadState.Success;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _state = UploadState.Error;
        }
    }

    private void Reset()
    {
        _file  = null;
        _error = string.Empty;
        _state = UploadState.Idle;
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024               => $"{bytes} B",
        < 1024 * 1024        => $"{bytes / 1024.0:F1} KB",
        < 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _                    => $"{bytes / (1024.0 * 1024 * 1024):F2} GB"
    };
}
