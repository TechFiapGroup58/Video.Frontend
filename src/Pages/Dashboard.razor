@page "/dashboard"
@inject IAuthService   Auth
@inject IUploadService Upload

<PageTitle>Dashboard — FIAP X</PageTitle>

<div class="page">
    <div class="page__header">
        <div>
            <h1 class="page__title">Dashboard</h1>
            <p class="page__subtitle">Olá, <strong>@_session?.FullName</strong>! Bem-vindo ao FIAP X.</p>
        </div>
        <a href="/upload" class="btn btn--primary">↑ Enviar vídeo</a>
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Carregando...</span>
        </div>
    }
    else
    {
        <!-- Cards de resumo -->
        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-card__value">@_total</span>
                <span class="stat-card__label">Total de uploads</span>
            </div>
            <div class="stat-card stat-card--green">
                <span class="stat-card__value">@_uploaded</span>
                <span class="stat-card__label">Enviados com sucesso</span>
            </div>
            <div class="stat-card stat-card--blue">
                <span class="stat-card__value">@_processing</span>
                <span class="stat-card__label">Em processamento</span>
            </div>
            <div class="stat-card stat-card--red">
                <span class="stat-card__value">@_failed</span>
                <span class="stat-card__label">Falhos</span>
            </div>
        </div>

        <!-- Últimos uploads -->
        <div class="section">
            <div class="section__header">
                <h2 class="section__title">Últimos uploads</h2>
                <a href="/videos" class="link">Ver todos →</a>
            </div>

            @if (_recent.Any())
            {
                <div class="table-wrapper">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Arquivo</th>
                                <th>Tamanho</th>
                                <th>Status</th>
                                <th>Data</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in _recent)
                            {
                                <tr>
                                    <td class="table__filename">@v.OriginalFileName</td>
                                    <td>@FormatSize(v.FileSizeBytes)</td>
                                    <td><StatusBadge Status="(VideoStatus)v.Status" /></td>
                                    <td>@v.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <span class="empty-state__icon">▶</span>
                    <p>Nenhum vídeo enviado ainda.</p>
                    <a href="/upload" class="btn btn--secondary">Enviar primeiro vídeo</a>
                </div>
            }
        </div>
    }
</div>

@code {
    private UserSession?                  _session;
    private IEnumerable<VideoUploadSummary> _recent    = Enumerable.Empty<VideoUploadSummary>();
    private bool _loading    = true;
    private int  _total      = 0;
    private int  _uploaded   = 0;
    private int  _processing = 0;
    private int  _failed     = 0;

    protected override async Task OnInitializedAsync()
    {
        _session = await Auth.GetSessionAsync();

        try
        {
            var all = (await Upload.ListAsync()).ToList();
            _total      = all.Count;
            _uploaded   = all.Count(v => v.Status == (int)VideoStatus.Uploaded);
            _processing = all.Count(v => v.Status == (int)VideoStatus.Processing);
            _failed     = all.Count(v => v.Status == (int)VideoStatus.Failed);
            _recent     = all.OrderByDescending(v => v.CreatedAt).Take(5);
        }
        catch { /* silencioso no dashboard */ }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024               => $"{bytes} B",
        < 1024 * 1024        => $"{bytes / 1024.0:F1} KB",
        < 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _                    => $"{bytes / (1024.0 * 1024 * 1024):F2} GB"
    };
}
