@page "/videos"
@inject IUploadService Upload

<PageTitle>Meus Vídeos — FIAP X</PageTitle>

<div class="page">
    <div class="page__header">
        <div>
            <h1 class="page__title">Meus Vídeos</h1>
            <p class="page__subtitle">Histórico de todos os seus uploads</p>
        </div>
        <a href="/upload" class="btn btn--primary">↑ Novo upload</a>
    </div>

    <!-- Filtros -->
    <div class="filters">
        <select class="filter-select" @bind="_filter">
            <option value="">Todos os status</option>
            <option value="0">Aguardando</option>
            <option value="1">Enviado</option>
            <option value="2">Falhou</option>
            <option value="10">Processando</option>
            <option value="11">Concluído</option>
        </select>

        <input class="filter-input" type="search"
               placeholder="Buscar por nome..."
               @bind="_search" @bind:event="oninput" />
    </div>

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Carregando vídeos...</span>
        </div>
    }
    else if (!_filtered.Any())
    {
        <div class="empty-state">
            <span class="empty-state__icon">▤</span>
            <p>Nenhum vídeo encontrado.</p>
            <a href="/upload" class="btn btn--secondary">Enviar vídeo</a>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Arquivo</th>
                        <th>Tamanho</th>
                        <th>Status</th>
                        <th>Enviado em</th>
                        <th>Erro</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in _filtered)
                    {
                        <tr class="@(v.Status == (int)VideoStatus.Failed ? "table__row--error" : "")">
                            <td class="table__filename">
                                <span class="file-icon">▶</span>
                                @v.OriginalFileName
                            </td>
                            <td>@FormatSize(v.FileSizeBytes)</td>
                            <td><StatusBadge Status="(VideoStatus)v.Status" /></td>
                            <td>@v.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="table__error">
                                @if (!string.IsNullOrEmpty(v.ErrorMessage))
                                {
                                    <span title="@v.ErrorMessage">⚠ Ver detalhe</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="table-footer">
            <span>@_filtered.Count() registros</span>
            <button class="btn btn--ghost btn--sm" @onclick="Reload">↺ Atualizar</button>
        </div>
    }
</div>

@code {
    private IEnumerable<VideoUploadSummary> _all      = Enumerable.Empty<VideoUploadSummary>();
    private bool   _loading = true;
    private string _search  = string.Empty;
    private string _filter  = string.Empty;

    private IEnumerable<VideoUploadSummary> _filtered =>
        _all.Where(v =>
            (string.IsNullOrEmpty(_filter) || v.Status.ToString() == _filter) &&
            (string.IsNullOrEmpty(_search) || v.OriginalFileName.Contains(_search, StringComparison.OrdinalIgnoreCase))
        ).OrderByDescending(v => v.CreatedAt);

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _loading = true;
        try { _all = await Upload.ListAsync(); }
        catch { }
        finally { _loading = false; }
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024               => $"{bytes} B",
        < 1024 * 1024        => $"{bytes / 1024.0:F1} KB",
        < 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _                    => $"{bytes / (1024.0 * 1024 * 1024):F2} GB"
    };
}
